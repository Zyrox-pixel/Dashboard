# Fichier de configuration d'environnement exemple
# Copiez ce fichier vers .env et ajustez les valeurs selon votre environnement

# URL de base de votre tenant Dynatrace
# Remplacez "your-tenant-id" par l'ID de votre tenant
REACT_APP_DYNATRACE_HOST=https://your-tenant-id.live.dynatrace.com

# URL de l'API backend
# Par défaut, l'API est sur localhost:5000
REACT_APP_API_URL=http://localhost:5000/api